{
  "name": "@miden-sdk/react",
  "version": "0.14.8",
  "description": "React hooks library for Miden Web Client",
  "type": "module",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./lazy": {
      "types": "./dist/lazy.d.ts",
      "default": "./dist/lazy.mjs"
    },
    "./mt": {
      "types": "./dist/mt.d.ts",
      "default": "./dist/mt.mjs"
    },
    "./mt/lazy": {
      "types": "./dist/mt/lazy.d.ts",
      "default": "./dist/mt/lazy.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "lazy",
    "mt",
    "README.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "VITE_CJS_IGNORE_WARNING=1 vitest run",
    "test:unit": "VITE_CJS_IGNORE_WARNING=1 vitest run",
    "test:coverage": "VITE_CJS_IGNORE_WARNING=1 vitest run --coverage",
    "test:integration": "pnpm build && playwright test",
    "test:all": "VITE_CJS_IGNORE_WARNING=1 vitest run && playwright test"
  },
  "peerDependencies": {
    "@miden-sdk/miden-sdk": "^0.14.8",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@miden-sdk/miden-sdk": "workspace:*",
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.30.1",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "miden",
    "react",
    "hooks",
    "blockchain",
    "rollup",
    "zk"
  ],
  "author": "Miden Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xMiden/web-sdk"
  },
  "bugs": {
    "url": "https://github.com/0xMiden/web-sdk/issues"
  }
}
